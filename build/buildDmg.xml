<project name="buildDmg" default="makeall" basedir="../">
  <property environment="env"/>

  <property name="build.artifacts" location="${basedir}"/>
  <property name="build.tmp" location="${basedir}/mac"/>
  <property name="build.layout" location="${basedir}"/>
  <loadproperties srcfile="${build.artifacts}/build.properties"/>

  <property name="build.code" value="${mps.build.number}" />
  <property name="mps-macos.zip" location="${build.artifacts}/${mps.build.number}-macos.zip"/>
  <property name="jdk.tar.gz" location="${build.artifacts}/jbr-osx-x64.tar.gz"/>
  <property name="jdk.m1.tar.gz" location="${build.artifacts}/jbr-osx-aarch64.tar.gz"/>

  <property name="mac.host" value=""/>
  <property name="mac.user" value=""/>
  <property name="mac.password" value=""/>
  <property name="mac.codesign.string" value=""/>
  <property name="mac.keychain" value="/Users/${mac.user}/Library/Keychains/login.keychain"/>
  <property name="mac.ftp.passive" value="true"/>
  <property name="remote.dir.base" value="intellij-builds"/>
  <property name="remote.dir" value="${remote.dir.base}/${build.code}"/>


  <target name="makeall">
    <mkdir dir="${build.tmp}"/>
    <copy file="${basedir}/build/resources/DMG_background.tiff" tofile="${build.tmp}/${build.code}.png"/>
    <copy file="${basedir}/build/resources/mps-sign.sh" tofile="${build.tmp}/${build.code}-sign.sh"/>
    <copy file="${basedir}/build/tools/mac/scripts/notarize.sh" tofile="${build.tmp}/notarize.sh"/>
    <copy file="${basedir}/build/resources/mps-dmg.sh" tofile="${build.tmp}/${build.code}-dmg.sh"/>
    <copy file="${basedir}/build/resources/mpsdmg.pl" tofile="${build.tmp}/${build.code}.pl"/>
    <copy file="${basedir}/build/tools/mac/scripts/entitlements.xml" tofile="${build.tmp}/entitlements.xml"/>
    <move file="${mps-macos.zip}" tofile="${build.tmp}/${build.code}.zip"/>

    <ftp server="${mac.host}" remotedir="${remote.dir}" action="mkdir" passive="${mac.ftp.passive}" userid="${mac.user}" password="${mac.password}"/>

    <ftp server="${mac.host}" remotedir="${remote.dir}" action="send" binary="true" passive="${mac.ftp.passive}" userid="${mac.user}" password="${mac.password}">
      <fileset file="${build.tmp}/${build.code}.png"/>
      <fileset file="${build.tmp}/${build.code}.zip"/>
    </ftp>
    <ftp server="${mac.host}" remotedir="${remote.dir}" action="put" chmod="777" binary="false" passive="${mac.ftp.passive}" userid="${mac.user}" password="${mac.password}">
      <fileset dir="${build.tmp}">
        <include name="${build.code}-sign.sh"/>
        <include name="${build.code}-dmg.sh"/>
        <include name="${build.code}.pl"/>
        <include name="entitlements.xml"/>
        <include name="notarize.sh"/>
      </fileset>
    </ftp>

    <!-- create -macos-no-jdk.dmg -->
    <!--sshexec host="${mac.host}" username="${mac.user}" password="${mac.password}" trust="yes"
             command="${remote.dir}/${build.code}-sign.sh ${build.code} ${mac.keychain} ${mac.password} ${remote.dir} ${mac.codesign.string}"/>
    <sshexec host="${mac.host}" username="${mac.user}" password="${mac.password}" trust="yes"
             command="${remote.dir}/${build.code}-dmg.sh ${build.code} ${remote.dir}"/-->

    <!--ftp server="${mac.host}" remotedir="${remote.dir}" action="get" binary="true" passive="${mac.ftp.passive}" userid="${mac.user}" password="${mac.password}">
      <fileset dir="${build.tmp}">
        <include name="**/${build.code}.dmg"/>
      </fileset>
    </ftp>
    <move file="${build.tmp}/${build.code}.dmg" tofile="${build.layout}/${build.code}-macos-no-jdk.dmg"/-->

    <!-- create -macos.dmg -->
    <move file="${jdk.tar.gz}" tofile="${build.tmp}/${build.code}-jdk.tar.gz"/>
    <ftp server="${mac.host}" remotedir="${remote.dir}" action="send" binary="true" passive="${mac.ftp.passive}" userid="${mac.user}" password="${mac.password}">
      <fileset file="${build.tmp}/${build.code}-jdk.tar.gz"/>
    </ftp>

    <sshexec host="${mac.host}" username="${mac.user}" password="${mac.password}" trust="yes"
             command="${remote.dir}/${build.code}-sign.sh ${build.code} ${mac.keychain} ${mac.password} ${remote.dir} ${mac.codesign.string}"/>
    <sshexec host="${mac.host}" username="${mac.user}" password="${mac.password}" trust="yes"
             command="${remote.dir}/${build.code}-dmg.sh ${build.code} ${remote.dir}"/>

    <ftp server="${mac.host}" remotedir="${remote.dir}" action="get" binary="true" passive="${mac.ftp.passive}" userid="${mac.user}" password="${mac.password}">
      <fileset dir="${build.tmp}">
        <include name="**/${build.code}.dmg"/>
      </fileset>
    </ftp>
    <move file="${build.tmp}/${build.code}.dmg" tofile="${build.layout}/${build.code}-macos.dmg"/>

    <!-- create -macos-aarch64.dmg -->
    <move file="${jdk.m1.tar.gz}" tofile="${build.tmp}/${build.code}-jdk.tar.gz"/>
    <ftp server="${mac.host}" remotedir="${remote.dir}" action="send" binary="true" passive="${mac.ftp.passive}" userid="${mac.user}" password="${mac.password}" verbose="yes">
      <fileset file="${build.tmp}/${build.code}-jdk.tar.gz"/>
    </ftp>

    <sshexec host="${mac.host}" username="${mac.user}" password="${mac.password}" trust="yes"
             command="${remote.dir}/${build.code}-sign.sh ${build.code} ${mac.keychain} ${mac.password} ${remote.dir} ${mac.codesign.string}"/>
    <sshexec host="${mac.host}" username="${mac.user}" password="${mac.password}" trust="yes"
             command="${remote.dir}/${build.code}-dmg.sh ${build.code} ${remote.dir}"/>

    <ftp server="${mac.host}" remotedir="${remote.dir}" action="get" binary="true" passive="${mac.ftp.passive}" userid="${mac.user}" password="${mac.password}">
      <fileset dir="${build.tmp}">
        <include name="**/${build.code}.dmg"/>
      </fileset>
    </ftp>
    <move file="${build.tmp}/${build.code}.dmg" tofile="${build.layout}/${build.code}-macos-aarch64.dmg"/>

    <!-- clean-up -->
    <ftp server="${mac.host}" remotedir="${remote.dir}" action="delete" passive="${mac.ftp.passive}" userid="${mac.user}" password="${mac.password}">
      <fileset dir="${build.layout}">
        <include name="**/${build.code}.zip"/>
        <include name="**/${build.code}-jdk.tar.gz"/>
        <include name="**/${build.code}-sign.sh"/>
        <include name="**/${build.code}-dmg.sh"/>
        <include name="**/${build.code}.png"/>
        <include name="**/${build.code}.pl"/>
        <include name="**/entitlements.xml"/>
        <include name="**/notarize.sh"/>
        <include name="**/${build.code}.sit"/>
        <include name="**/${build.code}.dmg"/>
      </fileset>
    </ftp>
    <delete dir="${build.tmp}"/>

    <fail message=".dmg build failed">
      <condition>
        <not>
          <and>
            <available file="${build.layout}/${build.code}-macos.dmg"/>
            <available file="${build.layout}/${build.code}-macos-aarch64.dmg"/>
          </and>
        </not>
      </condition>
    </fail>

  </target>

</project>
