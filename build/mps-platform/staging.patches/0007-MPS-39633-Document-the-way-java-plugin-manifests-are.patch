From b61946503f1c2d706b99abfa187c95950c28a86e Mon Sep 17 00:00:00 2001
From: Fedor Isakov <fedor.isakov@jetbrains.com>
Date: Wed, 22 Apr 2026 12:31:42 +0200
Subject: [PATCH 7/9] MPS-39633 Document the way java plugin manifests are
 patched

---
 community/mps/build/build/build.xml | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/community/mps/build/build/build.xml b/community/mps/build/build/build.xml
index 64eb99c52a908..6b0d4a4bda6e4 100644
--- a/community/mps/build/build/build.xml
+++ b/community/mps/build/build/build.xml
@@ -62,6 +62,8 @@
   <target name="repackage" depends="repackage-app-jar,repackage-java-plugin,extract-plugin-xml,extract-win-exe"/>
 
   <!--In java-impl.jar, we remove META-INF contents for Idea not to try loading plugins from it (see MPS-30538) -->
+  <!--In java-impl.jar, we we then replace META-INF/plugin.xml with a minimal set of modules -->
+  <!--In java-impl.jar, we replace META-INF/JavaPlugin.xml with a minimal configuration (see MPS-39633)-->
   <target name="repackage-java-plugin" description="Remove IDEA specific descriptors">
     <jar destfile="${target.dist}/plugins/java/lib/stripped.jar">
       <zipfileset src="${target.dist}/plugins/java/lib/java-impl.jar" excludes="META-INF/**" />
-- 
