From: Fedor Isakov <fedor.isakov@jetbrains.com>
Date: Wed, 6 May 2026 13:43:57 +0200
Subject: [PATCH 10/10] MPS-39682 Tree: restore cached presentation when root
 is already loaded

Co-Authored-By: Claude Sonnet 4.6 (1M context) <noreply@anthropic.com>
---
 .../com/intellij/ui/tree/AsyncTreeModel.java  | 15 ++++++++-
 .../com/intellij/ui/tree/TreeStateTest.kt     | 32 +++++++++++++++++++
 2 files changed, 46 insertions(+), 1 deletion(-)

diff --git a/community/platform/platform-impl/src/com/intellij/ui/tree/AsyncTreeModel.java b/community/platform/platform-impl/src/com/intellij/ui/tree/AsyncTreeModel.java
index c02dafef88906..37cc74fbf5eac 100644
--- a/community/platform/platform-impl/src/com/intellij/ui/tree/AsyncTreeModel.java
+++ b/community/platform/platform-impl/src/com/intellij/ui/tree/AsyncTreeModel.java
@@ -1248,11 +1248,24 @@ public final class AsyncTreeModel extends AbstractTreeModel
   @Override
   public void setCachedPresentation(@Nullable CachedTreePresentation presentation) {
     tree.cachedPresentation = presentation;
-    if (tree.root == null && presentation != null) {
+    if (presentation == null) {
+      return;
+    }
+    if (tree.root == null) {
       var rootPath = new CachingTreePath(presentation.getRoot());
       tree.root = toNode(null, presentation, rootPath);
       treeStructureChanged(new CachingTreePath(tree.root.object), null, null);
     }
+    else {
+      presentation.rootLoaded(tree.root.object);
+      if (tree.root.isLoadingRequired() || tree.root.loading != null) {
+        var cachedNodes = getChildrenFromCachedPresentation(tree.root);
+        if (cachedNodes != null) {
+          tree.root.setChildren(cachedNodes);
+          treeStructureChanged(new CachingTreePath(tree.root.object), null, null);
+        }
+      }
+    }
   }
 
   @Override
