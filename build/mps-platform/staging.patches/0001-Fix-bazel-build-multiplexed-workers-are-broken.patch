From cfb6c54a7719e22d513d79e0016fd27a5d7845c6 Mon Sep 17 00:00:00 2001
From: Fedor Isakov <fedor.isakov@jetbrains.com>
Date: Mon, 22 Jun 2026 15:22:50 +0200
Subject: [PATCH 1/2] Fix bazel build: multiplexed workers are broken

Bazel build of IJPL uses --experimental_worker_multiplex option, which can break the build.
The usual symptomps are: Bazel reports an error: "Worker process returned an unparseable WorkResponse!".
This patch fixes this issue by disabling multiplex worker feature temprorarily.
---
 community/mps/build/build/build.xml | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/community/mps/build/build/build.xml b/community/mps/build/build/build.xml
index 3e68825866528..1259b44e3269b 100644
--- a/community/mps/build/build/build.xml
+++ b/community/mps/build/build/build.xml
@@ -46,6 +46,9 @@
     <exec failonerror="true" executable="${platform.root}/bazel.cmd" dir="${platform.root}">
       <arg value="run"/>
       <arg value="//mps/build:mps_builder"/>
+      <arg value="--verbose_failures"/>
+      <arg value="--strategy=JvmCompile=worker"/>
+      <arg value="--noexperimental_worker_multiplex"/>
       <arg value="--"/>
       <arg value="${platform.root}"/>
     </exec>
-- 
2.53.0

