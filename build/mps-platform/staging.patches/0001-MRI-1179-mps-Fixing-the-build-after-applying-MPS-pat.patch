Subject: [PATCH 01/10] MRI-1179 mps: Fixing the build after applying MPS
 patches

---
 community/mps/build/build/build.xml | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/community/mps/build/build/build.xml b/community/mps/build/build/build.xml
index 9e0675a11d9fa..64eb99c52a908 100644
--- a/community/mps/build/build/build.xml
+++ b/community/mps/build/build/build.xml
@@ -41,6 +41,8 @@
     <apply.patch file="${basedir}/patches/MPS-38229.patch"/>
     <apply.patch file="${basedir}/patches/MPS-38534-WelcomeScreenPromotions_for251.patch"/>
     <apply.patch file="${basedir}/patches/WindowsDistribution.patch"/>
+    <!-- After patching the platform build looks for .mps project folder instead of .idea -->
+    <symlink link="${platform.root}/.mps" resource="${platform.root}/.idea"/>
   </target>
 
   <!-- Raw JPS build of modules and plugins required by MPS -->
