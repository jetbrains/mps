<ivy-module version="2.0" xmlns:m="http://ant.apache.org/ivy/maven">
  <info organisation="org.jetbrains.mps" module="idea-platform"/>
  <dependencies>
    <dependency org="org.jetbrains.kotlin" name="kotlin-stdlib" rev="${kotlin.version}">
      <!-- jvm library -->
      <artifact name="kotlin-stdlib" ext="jar"/>
      <artifact name="kotlin-stdlib" m:classifier="sources" ext="jar"/>
      <artifact name="kotlin-stdlib" m:classifier="javadoc" ext="jar"/>

      <!-- -all is the common library -->
      <artifact name="kotlin-stdlib-all" ext="jar"/>
      <artifact name="kotlin-stdlib-all" m:classifier="sources" ext="jar"/>
      <artifact name="kotlin-stdlib-all" m:classifier="javadoc" ext="jar"/>
    </dependency>
    <dependency org="org.jetbrains.kotlin" name="kotlin-compiler-embeddable" rev="${kotlin.version}">
      <!-- We only need that to extract builtins -->
      <artifact name="kotlin-compiler-embeddable" ext="jar"/>
    </dependency>
  </dependencies>
</ivy-module>