<?xml version="1.0" encoding="UTF-8"?>
<ivy-settings>
  <settings defaultResolver="main" />
  <caches defaultCacheDir="${mps.ivy.home}/.ivy2/cache" />
  <!--Authentication required for publishing (deployment). 'Artifactory Realm' is the realm used by Artifactory so don't change it.-->
  <credentials host="repository.jetbrains.com" realm="Artifactory Realm" username="mps" passwd="" />
  <resolvers>
    <chain name="main">
      <ibiblio name="public" m2compatible="true" root="https://repository.jetbrains.com/all" />
      <url name="maven" m2compatible="true">
        <artifact pattern="http://repo1.maven.org/maven2/[organization]/[module]/[revision]/[module]-[revision](-[classifier]).[ext]" />
      </url>
    </chain>
  </resolvers>
</ivy-settings>