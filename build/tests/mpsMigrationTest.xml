<project name="mpsMigration" default="checkAll" basedir="../..">
  <property name="env.JAVA_HOME" value="${java.home}/.."/>
  <property name="jdk.home" value="${env.JAVA_HOME}"/>

  <property name="project.simpleMigration" location="${basedir}/testbench/modules/testMigration"/>
  <property name="project.consMigrations" location="${basedir}/testbench/modules/testConsMigrations"/>
  <property name="project.migrationTaskPlugin" location="${basedir}/testbench/modules/testMigrationTaskAdditionalPlugin"/>
  <property name="test_classes" location="${basedir}/testbench/testclasses"/>

  <!--this will be specified by test.xml-->
  <property name="mps_home" location="build/artifacts/mps"/>

  <!-- see mpsSmartRefAttrMigration.xml for explanation. In this script,
       I test different approaches, with and without mpsHome attr, therefore define it-->
  <property name="artifacts.mps" location="${mps_home}"/>

  <path id="path.mps.ant.path">
    <pathelement location="${mps_home}/lib/ant/lib/ant-mps.jar" />
    <fileset dir="${mps_home}/lib">
      <include name="util.jar" />
      <include name="3rd-party-rt.jar" />
    </fileset>
  </path>

  <path id="test_classpath">
    <fileset dir="${mps_home}/lib">
      <include name="**/*.jar" />
    </fileset>
    <pathelement path="${jdk.home}/lib/tools.jar" />
    <pathelement path="${test_classes}"/>
  </path>

  <taskdef resource="jetbrains/mps/build/ant/antlib.xml" classpathref="path.mps.ant.path"/>

  <target name="compileTestClasses">
    <mkdir dir="${test_classes}"/>
    <javac destdir="${test_classes}" fork="false" includeantruntime="false" source="1.7" target="1.7">
      <compilerarg value="-Xlint:none"/>
      <classpath refid="test_classpath"/>
      <src>
        <path location="${basedir}/testbench/tests/jetbrains/mps/ant"/>
      </src>
    </javac>
  </target>

  <jvmargs id="just-assert">
    <arg value="-ea" />
  </jvmargs>

  <jvmargs id="illegal-access-override">
    <arg value="-ea" />
    <arg value="--add-opens=java.base/java.io=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/java.lang=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/java.lang.reflect=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/java.net=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/java.nio=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/java.nio.charset=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/java.text=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/java.time=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/java.util=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/java.util.concurrent=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/java.util.concurrent.atomic=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/jdk.internal.vm=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/sun.nio.ch=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/sun.security.ssl=ALL-UNNAMED" />
    <arg value="--add-opens=java.base/sun.security.util=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/java.awt=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/java.awt.dnd.peer=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/java.awt.event=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/java.awt.image=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/java.awt.peer=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/javax.swing=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/javax.swing.plaf.basic=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/javax.swing.text.html=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/sun.awt.datatransfer=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/sun.awt.image=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/sun.awt=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/sun.font=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/sun.java2d=ALL-UNNAMED" />
    <arg value="--add-opens=java.desktop/sun.swing=ALL-UNNAMED" />
    <arg value="--add-opens=jdk.attach/sun.tools.attach=ALL-UNNAMED" />
    <arg value="--add-opens=jdk.compiler/com.sun.tools.javac.api=ALL-UNNAMED" />
    <arg value="--add-opens=jdk.internal.jvmstat/sun.jvmstat.monitor=ALL-UNNAMED" />
    <arg value="--add-opens=jdk.jdi/com.sun.tools.jdi=ALL-UNNAMED" />
  </jvmargs>

  <target name="checkAll" depends="compileTestClasses">
    <migrate project="${project.simpleMigration}" mpsHome="${mps_home}" makeDistribModules="false" force="true">
      <jvmargs>
        <arg value="-Didea.log.config.file=log.xml"/>
        <!--<arg value="-agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=5071" />-->
        <arg value="--add-opens=java.base/java.io=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/java.lang=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/java.lang.reflect=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/java.net=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/java.nio=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/java.nio.charset=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/java.text=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/java.time=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/java.util=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/java.util.concurrent=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/java.util.concurrent.atomic=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/jdk.internal.vm=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/sun.nio.ch=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/sun.security.ssl=ALL-UNNAMED" />
        <arg value="--add-opens=java.base/sun.security.util=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/java.awt=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/java.awt.dnd.peer=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/java.awt.event=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/java.awt.image=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/java.awt.peer=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/javax.swing=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/javax.swing.plaf.basic=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/javax.swing.text.html=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/sun.awt.datatransfer=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/sun.awt.image=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/sun.awt=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/sun.font=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/sun.java2d=ALL-UNNAMED" />
        <arg value="--add-opens=java.desktop/sun.swing=ALL-UNNAMED" />
        <arg value="--add-opens=jdk.attach/sun.tools.attach=ALL-UNNAMED" />
        <arg value="--add-opens=jdk.compiler/com.sun.tools.javac.api=ALL-UNNAMED" />
        <arg value="--add-opens=jdk.internal.jvmstat/sun.jvmstat.monitor=ALL-UNNAMED" />
        <arg value="--add-opens=jdk.jdi/com.sun.tools.jdi=ALL-UNNAMED" />
      </jvmargs>
    </migrate>

    <junit fork="true" dir="${mps_home}" showoutput="true">
      <classpath refid="test_classpath"/>
      <jvmarg value="-Dtest.output.dir=${project.simpleMigration}"/>
      <test name="jetbrains.mps.ant.TestAntTaskResult" methods="testSimpleMigration"/>
      <formatter type="xml" extension=".testSimpleMigration.xml"/>
    </junit>

    <migrate makeDistribModules="false" force="true"> <!-- implicit mpsHome through artifacts.mps value-->
      <project path="${project.consMigrations}"/>
      <jvmargs refid="illegal-access-override"/>
    </migrate>

    <junit fork="true" dir="${mps_home}" showoutput="true">
      <classpath refid="test_classpath"/>
      <jvmarg value="-Dtest.output.dir=${project.consMigrations}"/>
      <test name="jetbrains.mps.ant.TestAntTaskResult" methods="testConsequentMigrations"/>
      <formatter type="xml" extension=".testConsequentMigrations.xml"/>
    </junit>

    <migrate project="${project.migrationTaskPlugin}" makeDistribModules="false" force="true"> <!-- implicit mpsHome through artifacts.mps value-->
      <plugin path="${mps_home}/plugins/mps-httpsupport/" id="jetbrains.mps.ide.httpsupport"/>
      <jvmargs refid="illegal-access-override"/>
    </migrate>

    <junit fork="true" dir="${mps_home}" showoutput="true">
      <classpath refid="test_classpath"/>
      <jvmarg value="-Dtest.output.dir=${project.migrationTaskPlugin}"/>
      <test name="jetbrains.mps.ant.TestAntTaskResult" methods="testMigrationTaskAdditionalPlugin"/>
      <formatter type="xml" extension=".testMigrationTaskAdditionalPlugin.xml"/>
    </junit>
  </target>
</project>
