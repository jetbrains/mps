<?xml version="1.0" encoding="UTF-8"?>
<ivy-settings>
  <settings defaultResolver='public'/>
  <caches defaultCacheDir="${mps.ivy.home}/.ivy2/cache"/>
  <resolvers>
    <url name="public" m2compatible="true">
      <artifact pattern="https://repository.jetbrains.com/all/[organization]/[module]/[revision]/[module]-[revision](-[classifier]).[ext]" />
    </url>
  </resolvers>
</ivy-settings>