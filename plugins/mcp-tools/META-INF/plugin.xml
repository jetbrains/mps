<idea-plugin>
  <id>com.intellij.mcp.tools</id>
  <name>MCP MPS</name>
  <vendor>JetBrains</vendor>
  <description>A plugin enabling MPS mcp tools to AI coding agents.</description>

  <depends>com.intellij.mcpServer</depends>
  <depends>jetbrains.mps.core</depends>
  <depends>com.intellij.modules.mps</depends>
  <depends>jetbrains.mps.ide.java</depends>

  <extensions defaultExtensionNs="com.intellij">
    <mcpServer.mcpToolset implementation="com.intellij.mcp.tools.JetBrainsMPSSkillsMcpToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcp.tools.JetBrainsMPSProjectMcpToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcp.tools.JetBrainsMPSLanguageMcpToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcp.tools.JetBrainsMPSModuleMcpToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcp.tools.JetBrainsMPSModelMcpToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcp.tools.JetBrainsMPSRootNodeMcpToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcp.tools.JetBrainsMPSNodeMcpToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcp.tools.JetBrainsMPSEditorMcpToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcp.tools.JetBrainsMPSLanguageStructureMcpToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcp.tools.JetBrainsMPSJavaMcpToolset" />
  </extensions>
</idea-plugin>
