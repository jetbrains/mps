<idea-plugin>
  <id>jetbrains.mps.agents.mcp.tools</id>
  <name>Projectional Agent Toolkit</name>
  <vendor>JetBrains</vendor>
  <description>A plugin enabling MPS mcp tools to AI coding agents.</description>
  <vendor url="http://www.jetbrains.com/mps/">JetBrains</vendor>

  <depends>com.intellij.mcpServer</depends>
  <depends>jetbrains.mps.core</depends>
  <depends>com.intellij.modules.mps</depends>
  <depends>jetbrains.mps.ide.java</depends>

  <extensions defaultExtensionNs="com.intellij">
    <mcpServer.mcpToolset implementation="jetbrains.mps.agents.mcp.tools.JetBrainsMPSProjectMcpToolset" />
    <mcpServer.mcpToolset implementation="jetbrains.mps.agents.mcp.tools.JetBrainsMPSConsoleMcpToolset" />
    <mcpServer.mcpToolset implementation="jetbrains.mps.agents.mcp.tools.JetBrainsMPSLanguageMcpToolset" />
    <mcpServer.mcpToolset implementation="jetbrains.mps.agents.mcp.tools.JetBrainsMPSModuleMcpToolset" />
    <mcpServer.mcpToolset implementation="jetbrains.mps.agents.mcp.tools.JetBrainsMPSModelMcpToolset" />
    <mcpServer.mcpToolset implementation="jetbrains.mps.agents.mcp.tools.JetBrainsMPSRootNodeMcpToolset" />
    <mcpServer.mcpToolset implementation="jetbrains.mps.agents.mcp.tools.JetBrainsMPSNodeMcpToolset" />
    <mcpServer.mcpToolset implementation="jetbrains.mps.agents.mcp.tools.JetBrainsMPSEditorMcpToolset" />
    <mcpServer.mcpToolset implementation="jetbrains.mps.agents.mcp.tools.JetBrainsMPSLanguageStructureMcpToolset" />
    <mcpServer.mcpToolset implementation="jetbrains.mps.agents.mcp.tools.JetBrainsMPSJavaMcpToolset" />
    <mcpServer.mcpToolset implementation="jetbrains.mps.agents.mcp.tools.JetBrainsMPSRunConfigurationMcpToolset" />
    <mcpServer.mcpToolset implementation="jetbrains.mps.agents.mcp.tools.JetBrainsMPSInitMcpToolset" />
  </extensions>
</idea-plugin>
